# --- Local environment ---
# API base URL used when the dashboard's environment selector is set to "Local"
VITE_API_URL=http://localhost:3000
# Content Studio base URL (Local)
VITE_CONTENT_STUDIO_URL=http://localhost:3002

# --- Production environment ---
# API base URL used when the environment selector is set to "Production"
VITE_PRODUCTION_API_URL=https://api.readmigo.app
# Content Studio base URL (Production)
VITE_PRODUCTION_CONTENT_STUDIO_URL=https://studio.readmigo.app

# --- Auth ---
# Set to "true" to bypass login with a mock admin user (DEV ONLY).
# WARNING: never enable in production builds.
VITE_AUTH_DISABLED=false

# --- Analytics ---
# PostHog Project API Key (public, for SDK event capture)
VITE_POSTHOG_PROJECT_API_KEY=
# PostHog Personal API Key (for management API queries)
VITE_POSTHOG_PERSONAL_API_KEY=
